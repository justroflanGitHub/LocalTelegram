# LocalTelegram Environment Configuration
# Copy this file to .env and update values as needed

# PostgreSQL Configuration
POSTGRES_USER=localtelegram
POSTGRES_PASSWORD=localtelegram123
POSTGRES_DB=localtelegram

# Redis Configuration
REDIS_PASSWORD=redis123

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# RabbitMQ Configuration
RABBITMQ_USER=localtelegram
RABBITMQ_PASSWORD=rabbitmq123

# JWT Settings
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ISSUER=localtelegram
JWT_AUDIENCE=localtelegram-users
JWT_EXPIRATION_HOURS=24

# Server URLs (for development)
API_GATEWAY_URL=http://localhost:5000
AUTH_SERVICE_URL=http://localhost:5001
MESSAGE_SERVICE_URL=http://localhost:5002
FILE_SERVICE_URL=http://localhost:5003

# File Storage
MAX_FILE_SIZE_BYTES=2147483648
CHUNK_SIZE_BYTES=5242880

# Logging
LOG_LEVEL=Information
